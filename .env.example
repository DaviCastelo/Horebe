# Opcional: sobrescreve a URL de reservas no Booking (lib/constants.ts)
# NEXT_PUBLIC_BOOKING_URL=https://www.booking.com/hotel/br/...

# Opcional: número principal de WhatsApp sem + (lib/constants.ts)
# NEXT_PUBLIC_WHATSAPP=5585988662996

# --- Área Admin (obrigatório para /admin) ---
# NUNCA commite .env.local nem coloque a senha no código.
# Defina em .env.local (não versionado):
# ADMIN_PASSWORD=sua_senha_secreta
# ADMIN_SESSION_SECRET=uma_string_aleatoria_com_pelo_menos_32_caracteres

# --- Persistência em produção (opcional, recomendado para Vercel) ---
# Se configurar Vercel KV, os pacotes especiais serão salvos externamente.
# KV_REST_API_URL=https://<seu-endpoint-upstash>.upstash.io
# KV_REST_API_TOKEN=<seu-token>

# --- Upload de imagens (Vercel Blob) ---
# Necessário para upload no /admin (pacotes especiais)
# BLOB_READ_WRITE_TOKEN=<seu-token-do-blob>
